# Backup automatique Google Drive (configurer dans Netlify Dashboard)
# Seules ces 3 variables sont obligatoires (memes que l'ATS) :
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxx
# GOOGLE_REFRESH_TOKEN=1//xxx
#
# Optionnel (auto-cree si absent, email alerte defaut: benjamin.fetu@amarillosearch.com) :
# GOOGLE_DRIVE_FOLDER_ID=xxx
# BACKUP_ALERT_EMAIL=benjamin.fetu@amarillosearch.com
#
# JSONBIN: reutilise automatiquement VITE_JSONBIN_MASTER_KEY et VITE_JSONBIN_BIN_ID
